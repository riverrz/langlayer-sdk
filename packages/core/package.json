{
  "name": "@langlayer-sdk/core",
  "version": "0.2.1",
  "description": "Core runtime for LangLayer",
  "repository": {
    "type": "git",
    "url": "https://github.com/riverrz/langlayer-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/riverrz/langlayer-sdk#readme",
  "bugs": {
    "url": "https://github.com/riverrz/langlayer-sdk/issues"
  },
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.mjs",
      "require": "./dist/devtools.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@langlayer-sdk/eslint-config": "workspace:*",
    "@langlayer-sdk/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  }
}

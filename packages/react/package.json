{
  "name": "@langlayer-sdk/react",
  "license": "MIT",
  "version": "0.1.2",
  "description": "React bindings for LangLayer core",
  "repository": {
    "type": "git",
    "url": "https://github.com/riverrz/langlayer-sdk.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/riverrz/langlayer-sdk#readme",
  "bugs": {
    "url": "https://github.com/riverrz/langlayer-sdk/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@langlayer-sdk/core": "workspace:*"
  },
  "devDependencies": {
    "@langlayer-sdk/eslint-config": "workspace:*",
    "@langlayer-sdk/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
